{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Music Downloader",
  "version": "0.1.0",
  "identifier": "com.youtube-dl.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YouTube Music Downloader",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost https: data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/**", "$TEMP/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "Developer ID Application: IDENTITY_PLACEHOLDER (TEAM_PLACEHOLDER)",
      "hardenedRuntime": true,
      "entitlements": "./Entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "signCommand": "signtool sign /tr http://timestamp.digicert.com /td sha256 /fd sha256 /sha1 %CERT_THUMBPRINT% %1",
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "UPDATER_PUBKEY_PLACEHOLDER",
      "endpoints": [
        "https://github.com/OWNER/REPO/releases/latest/download/latest.json"
      ]
    }
  }
}
